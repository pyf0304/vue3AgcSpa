{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome",
      "url": "http://localhost:8099",
      "runtimeArgs": [
        "--new-window",
        "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile"
      ],
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true
    }
  ]
}
