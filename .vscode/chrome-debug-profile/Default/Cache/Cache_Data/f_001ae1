              (x) => x.GetFldValue(strKey) <= strValue
            );
          } else if (strComparisonOp == ">") {
            arrFunctionTypeSel = arrFunctionTypeSel.filter((x) => x.GetFldValue(strKey) > strValue);
          } else if (strComparisonOp == "<") {
            arrFunctionTypeSel = arrFunctionTypeSel.filter(
              (x) => x.GetFldValue(strKey) <= strValue
