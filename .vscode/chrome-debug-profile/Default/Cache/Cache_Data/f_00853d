export async function TabType_IsExistRecordCache(objTabTypeCond) {
  const strThisFuncName = "IsExistRecordCache";
  const arrTabTypeObjLstCache = await TabType_GetObjLstCache();
  if (arrTabTypeObjLstCache == null)
    return false;
  let arrTabTypeSel = arrTabTypeObjLstCache;
  if (objTabTypeCond.GetConditions().length == 0)
    return arrTabTypeSel.length > 0 ? true : false;
  try {
    for (const objCondition of objTabTypeCond.GetConditions()) {
      if (objCondition == null)
        continue;
      const strKey = objCondition.fldName;
      const strComparisonOp = objCondition.comparison;
      const strValue = objCondition.fldValue;
      const strType = typeof strValue;
      switch (strType) {
        case "string":
          if (strValue == null)
            continue;
          if (strValue == "")
            continue;
          if (strComparisonOp == "=") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString() == strValue.toString()
            );
          } else if (strComparisonOp == "like") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().indexOf(strValue.toString()) != -1
            );
          } else if (strComparisonOp == "length greater") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().length > Number(strValue.toString())
            );
          } else if (strComparisonOp == "length not greater") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().length <= Number(strValue.toString())
            );
          } else if (strComparisonOp == "length not less") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().length >= Number(strValue.toString())
            );
          } else if (strComparisonOp == "length less") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().length < Number(strValue.toString())
            );
          } else if (strComparisonOp == "length equal") {
            arrTabTypeSel = arrTabTypeSel.filter(
              (x) => x.GetFldValue(strKey).toString().length == Number(strValue.toString())
            );
          }
          break;
        case "boolean":
          if (strValue == null)
            continue;
          if (strComparisonOp == "=") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) == strValue);
          }
          break;
        case "number":
          if (Number(strValue) == 0)
            continue;
          if (strComparisonOp == "=") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) == strValue);
          } else if (strComparisonOp == ">=") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) >= strValue);
          } else if (strComparisonOp == "<=") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) <= strValue);
          } else if (strComparisonOp == ">") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) > strValue);
          } else if (strComparisonOp == "<") {
            arrTabTypeSel = arrTabTypeSel.filter((x) => x.GetFldValue(strKey) <= strValue);
          }
          break;
      }
    }
    if (arrTabTypeSel.length > 0) {
      return true;
    } else {
      return false;
    }
  } catch (e) {
    const strMsg = Format(
      "根据条件:[{0}]判断是否存在不成功!(in {1}.{2})",
