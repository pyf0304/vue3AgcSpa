      arrUsersSel = arrUsersSel.filter((x) => x.GetFldValue(strKey) != null);
      const strType = typeof strValue;
      switch (strType) {
        case "string":
          if (strValue == null)
            continue;
          if (strValue == "")
            continue;
          if (strComparisonOp == "=") {
            arrUsersSel = arrUsersSel.filter(
