export async function TabMainType_IsExistRecordCache(objTabMainTypeCond) {
  const strThisFuncName = "IsExistRecordCache";
  const arrTabMainTypeObjLstCache = await TabMainType_GetObjLstCache();
  if (arrTabMainTypeObjLstCache == null)
    return false;
