        objPrjConstraint.SetConstraintName(strNormalConstraintName);
        objPrjConstraint.SetPrjId(clsPrivateSessionStorage.currSelPrjId);
        objPrjConstraint.SetUpdDate(clsDateTime.getTodayDateTimeStr(0));
