    const arrData = [];
    for (let i = 0; i < intRowNum; i++) {
      const objEN = arrDnPathObjLst[i];
      const objRow = {};
      for (let j = 0; j < intColNum; j++) {
        const fldName = arrDataColumn[j].fldName;
        const colHeader = arrDataColumn[j].colHeader;
