  static async CopyTextToClipboard(strText) {
    try {
      if (IsNullOrEmpty(strText) == true)
        return false;
      if (navigator != null && navigator.clipboard != null && navigator.clipboard.writeText != null) {
        await navigator.clipboard.writeText(strText);
        return true;
      }
      const textarea = document.createElement("textarea");
      textarea.value = strText;
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();
      const isCopied = document.execCommand("copy");
      document.body.removeChild(textarea);
      return isCopied;
    } catch (e) {
      console.error("复制失败:", e);
      return false;
    }
  }
