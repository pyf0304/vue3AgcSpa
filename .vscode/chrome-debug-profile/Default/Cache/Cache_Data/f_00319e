              (x) => x.GetFldValue(strKey) == strValue
            );
          } else if (strComparisonOp == ">=") {
            arrViewImplementationSel = arrViewImplementationSel.filter(
              (x) => x.GetFldValue(strKey) >= strValue
            );
          } else if (strComparisonOp == "<=") {
            arrViewImplementationSel = arrViewImplementationSel.filter(
              (x) => x.GetFldValue(strKey) <= strValue
