      console.error(data.errorMsg);
      throw data.errorMsg;
    }
  } catch (error) {
    console.error(error);
    if (error.statusText == void 0) {
      throw error;
    }
    if (error.statusText == "error") {
      const strInfo = Format(
        "网络错误！访问地址:{0}不成功！(in {1}.{2})",
