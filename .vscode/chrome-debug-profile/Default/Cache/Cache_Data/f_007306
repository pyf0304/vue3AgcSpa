    for (const objTd of arrTd) {
      const objChild = objTd.firstChild;
      if (objChild == null)
        continue;
      let strKeyId;
      let objChild_Html;
      switch (objChild.nodeName) {
        case "DIV":
          objChild_Html = objChild;
          strKeyId = objChild_Html.getAttribute("mid");
          break;
        case "A":
          objChild_Html = objChild;
          strKeyId = objChild_Html.getAttribute("mid");
          break;
        case "INPUT":
          objChild_Html = objChild;
          strKeyId = objChild_Html.getAttribute("mid");
          break;
        case "SELECT":
          objChild_Html = objChild;
          strKeyId = objChild_Html.getAttribute("mid");
          break;
        case "SPAN":
          objChild_Html = objChild;
          strKeyId = objChild_Html.getAttribute("mid");
          break;
      }
      if (objChild_Html == null)
        continue;
      if (strKeyId == null)
        continue;
      const objExcelExportRegionFld = await ExcelExportRegionFlds_GetObjBymIdCache(
        Number(strKeyId),
        strRegionId
      );
